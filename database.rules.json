{
  "rules": {
    ".read": false,
    ".write": false,

    "pending": {
      ".read": "auth != null",
      "$id": {
        ".write": "(!data.exists() && newData.exists()) || auth != null",
        ".validate": "newData.hasChildren(['name','at']) && newData.child('name').isString() && newData.child('name').val().length >= 1 && newData.child('name').val().length <= 5 && newData.child('name').val().matches(/^[가-힣a-zA-Z]+$/) && newData.child('at').isNumber()",
        "name": { ".validate": "newData.isString()" },
        "at":   { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },

    "approved": {
      ".read": true,
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChildren(['name','at']) && newData.child('name').isString() && newData.child('name').val().length <= 5 && newData.child('at').isNumber()",
        "name": { ".validate": "newData.isString()" },
        "at":   { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    }
  }
}
